DATABASE_URL=postgresql://postgres:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-supabase-service-or-anon-key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
EODHD_API_KEY=your-eodhd-api-token
# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]
# Resend transactional email — get key at resend.com → API Keys → Create (starts with re_)
RESEND_API_KEY=re_your_key_here
# Public URL of your frontend (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app
# Seed admin credentials (only needed when running seed_admin.py)
SEED_ADMIN_EMAIL=admin@yourschool.com
SEED_ADMIN_PASSWORD=change-me-strong-password
SEED_ADMIN_NOMBRE=Administrador
